# Copy to .env.local and fill in. NEXT_PUBLIC_* values are exposed to the
# browser by design (the Firebase web config is not secret).

# Backend API base (admin + public fetches, and the Enquire Google-login post)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: enables the /api/:path* rewrite proxy in next.config.ts
# NEXT_PUBLIC_BASE_URL=http://localhost:8000

# ─── Firebase web config (project: liquemix) ─────────────────────────
# Drives the public "Enquire → Continue with Google" sign-in. Get these
# from Firebase console → Project settings → Your apps → Web app → SDK config.
# If left blank, the Enquire flow simply shows the contact channels without
# the Google sign-in gate (the site still works).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=liquemix.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=liquemix
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=liquemix.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
