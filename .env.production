NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=liquemix.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=liquemix
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=liquemix.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=237100913064
NEXT_PUBLIC_FIREBASE_APP_ID=1:237100913064:web:1d7d24b42fa7d8154e0d9d
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-QDTFN4PK65
